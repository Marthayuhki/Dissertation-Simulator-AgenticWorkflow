# Academic Database API Keys
# Copy this file to .env and fill in your keys.
# See docs/academic-api-integration-guide.md for setup instructions.

# === Phase 1: No registration needed ===
# CrossRef: just put your email (no key needed)
CROSSREF_EMAIL=your@email.com

# Semantic Scholar: optional key for higher rate limits
# Get at: https://www.semanticscholar.org/product/api
# S2_API_KEY=

# arXiv: no key needed at all

# === Phase 2: Quick web registration (2 min each) ===
# OpenAlex: create account at https://openalex.org, get key at /settings/api
OPENALEX_API_KEY=

# CORE: register at https://core.ac.uk/services/api
# CORE_API_KEY=

# === Phase 3: Korean databases (data.go.kr registration) ===
# KCI: https://www.kci.go.kr/kciportal/po/openapi/openApiKeyRequest.kci
# KCI_API_KEY=

# DBpia: https://api.dbpia.co.kr/openApi/index.do
# DBPIA_API_KEY=

# RISS: https://www.data.go.kr (Dataset 3046254)
# RISS_API_KEY=

# ScienceON: register at ScienceON API Gateway portal
# SCIENCEON_CLIENT_ID=
# SCIENCEON_TOKEN=
